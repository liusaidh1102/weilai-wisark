<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.weilai.streaming.mapper.LivePermissionMapper">

    <resultMap type="com.weilai.model.streaming.dos.LivePermission" id="LivePermissionMap">
        <id property="id" column="id"/>
        <result property="liveId" column="live_id"/>
        <result property="permissionType" column="permission_type"/>
        <result property="password" column="password"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <!-- 添加直播权限 -->
    <insert id="insert" parameterType="com.weilai.model.streaming.dos.LivePermission">
        INSERT INTO `live_permission`(live_id, permission_type, password, created_at)
        VALUES (#{liveId}, #{permissionType}, #{password}, #{createdAt})
    </insert>

    <!-- 根据条件查询直播权限 -->
    <select id="selectList" parameterType="com.baomidou.mybatisplus.core.conditions.query.QueryWrapper" 
            resultMap="LivePermissionMap">
        SELECT * FROM `live_permission`
        <where>
            ${ew.sqlSegment}
        </where>
    </select>
    
    <!-- 根据ID查询直播权限 -->
    <select id="selectById" parameterType="java.lang.Long" resultMap="LivePermissionMap">
        SELECT * FROM `live_permission` WHERE id = #{id}
    </select>

    <!-- 更新直播权限 -->
    <update id="updateById" parameterType="com.weilai.model.streaming.dos.LivePermission">
        UPDATE `live_permission`
        <set>
            <if test="liveId != null">
                live_id = #{liveId},
            </if>
            <if test="permissionType != null">
                permission_type = #{permissionType},
            </if>
            <if test="password != null and password != ''">
                password = #{password},
            </if>
            <if test="createdAt != null">
                created_at = #{createdAt},
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 删除直播权限 -->
    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM `live_permission` WHERE id = #{id}
    </delete>

</mapper>