<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.weilai.streaming.mapper.LiveAllowUserMapper">

    <resultMap type="com.weilai.model.streaming.dos.LiveAllowUser" id="LiveAllowUserMap">
        <id property="id" column="id"/>
        <result property="liveId" column="live_id"/>
        <result property="userId" column="user_id"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <!-- 添加直播允许用户 -->
    <insert id="insert" parameterType="com.weilai.model.streaming.dos.LiveAllowUser">
        INSERT INTO `live_allow_user`(live_id, user_id, created_at)
        VALUES (#{liveId}, #{userId}, #{createdAt})
    </insert>

    <!-- 根据条件查询直播允许用户 -->
    <select id="selectList" parameterType="com.baomidou.mybatisplus.core.conditions.query.QueryWrapper" 
            resultMap="LiveAllowUserMap">
        SELECT * FROM `live_allow_user`
        <where>
            ${ew.sqlSegment}
        </where>
    </select>
    
    <!-- 根据ID查询直播允许用户 -->
    <select id="selectById" parameterType="java.lang.Long" resultMap="LiveAllowUserMap">
        SELECT * FROM `live_allow_user` WHERE id = #{id}
    </select>

    <!-- 删除直播允许用户 -->
    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM `live_allow_user` WHERE id = #{id}
    </delete>

</mapper>