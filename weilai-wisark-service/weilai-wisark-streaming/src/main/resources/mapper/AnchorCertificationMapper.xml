<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.weilai.streaming.mapper.AnchorCertificationMapper">

    <resultMap type="com.weilai.model.streaming.dos.AnchorCertification" id="AnchorCertificationMap">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="realName" column="real_name"/>
        <result property="idCard" column="id_card"/>
        <result property="title" column="title"/>
        <result property="organization" column="organization"/>
        <result property="introduction" column="introduction"/>
        <result property="status" column="status"/>
        <result property="rejectReason" column="reject_reason"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 添加主播认证信息 -->
    <insert id="insert" parameterType="com.weilai.model.streaming.dos.AnchorCertification">
        INSERT INTO `anchor_certification`(user_id, real_name, id_card, title, organization, introduction, status, reject_reason, created_at, updated_at)
        VALUES (#{userId}, #{realName}, #{idCard}, #{title}, #{organization}, #{introduction}, #{status}, #{rejectReason}, #{createdAt}, #{updatedAt})
    </insert>

    <!-- 根据条件查询主播认证信息 -->
    <select id="selectList" parameterType="com.baomidou.mybatisplus.core.conditions.query.QueryWrapper" 
            resultMap="AnchorCertificationMap">
        SELECT * FROM `anchor_certification`
        <where>
            ${ew.sqlSegment}
        </where>
    </select>
    
    <!-- 根据ID查询主播认证信息 -->
    <select id="selectById" parameterType="java.lang.Long" resultMap="AnchorCertificationMap">
        SELECT * FROM `anchor_certification` WHERE id = #{id}
    </select>

    <!-- 更新主播认证信息 -->
    <update id="updateById" parameterType="com.weilai.model.streaming.dos.AnchorCertification">
        UPDATE `anchor_certification`
        <set>
            <if test="userId != null">
                user_id = #{userId},
            </if>
            <if test="realName != null and realName != ''">
                real_name = #{realName},
            </if>
            <if test="idCard != null and idCard != ''">
                id_card = #{idCard},
            </if>
            <if test="title != null and title != ''">
                title = #{title},
            </if>
            <if test="organization != null and organization != ''">
                organization = #{organization},
            </if>
            <if test="introduction != null and introduction != ''">
                introduction = #{introduction},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="rejectReason != null and rejectReason != ''">
                reject_reason = #{rejectReason},
            </if>
            <if test="createdAt != null">
                created_at = #{createdAt},
            </if>
            <if test="updatedAt != null">
                updated_at = #{updatedAt},
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 删除主播认证信息 -->
    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM `anchor_certification` WHERE id = #{id}
    </delete>

</mapper>