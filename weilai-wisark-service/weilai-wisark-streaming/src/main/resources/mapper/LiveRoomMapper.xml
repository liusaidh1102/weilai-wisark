<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.weilai.streaming.mapper.LiveRoomMapper">

    <resultMap type="com.weilai.model.streaming.dos.LiveRoom" id="LiveRoomMap">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="title" column="title"/>
        <result property="coverImage" column="cover_image"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="startTime" column="start_time"/>
        <result property="actualStartTime" column="actual_start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="viewCount" column="view_count"/>
        <result property="likeCount" column="like_count"/>
        <result property="shareCount" column="share_count"/>
        <result property="isRecommended" column="is_recommended"/>
        <result property="replayUrl" column="replay_url"/>
        <result property="duration" column="duration"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deletedAt" column="deleted_at"/>
    </resultMap>

    <!-- 添加直播房间 -->
    <insert id="insert" parameterType="com.weilai.model.streaming.dos.LiveRoom">
        INSERT INTO `live_room`(user_id, title, cover_image, description, status, start_time, actual_start_time, end_time, view_count, like_count, share_count, is_recommended, replay_url, duration, created_at, updated_at)
        VALUES (#{userId}, #{title}, #{coverImage}, #{description}, #{status}, #{startTime}, #{actualStartTime}, #{endTime}, #{viewCount}, #{likeCount}, #{shareCount}, #{isRecommended}, #{replayUrl}, #{duration}, #{createdAt}, #{updatedAt})
    </insert>

    <!-- 根据条件查询直播房间 -->
    <select id="selectList" parameterType="com.baomidou.mybatisplus.core.conditions.query.QueryWrapper" 
            resultMap="LiveRoomMap">
        SELECT * FROM `live_room`
        <where>
            ${ew.sqlSegment}
        </where>
    </select>
    
    <!-- 根据条件查询单个直播房间 -->
    <select id="selectOne" parameterType="com.baomidou.mybatisplus.core.conditions.query.QueryWrapper" 
            resultMap="LiveRoomMap">
        SELECT * FROM `live_room`
        <where>
            ${ew.sqlSegment}
        </where>
        LIMIT 1
    </select>

    <!-- 更新直播房间 -->
    <update id="updateById" parameterType="com.weilai.model.streaming.dos.LiveRoom">
        UPDATE `live_room`
        <set>
            <if test="userId != null">
                user_id = #{userId},
            </if>
            <if test="title != null and title != ''">
                title = #{title},
            </if>
            <if test="coverImage != null and coverImage != ''">
                cover_image = #{coverImage},
            </if>
            <if test="description != null and description != ''">
                description = #{description},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="startTime != null">
                start_time = #{startTime},
            </if>
            <if test="actualStartTime != null">
                actual_start_time = #{actualStartTime},
            </if>
            <if test="endTime != null">
                end_time = #{endTime},
            </if>
            <if test="viewCount != null">
                view_count = #{viewCount},
            </if>
            <if test="likeCount != null">
                like_count = #{likeCount},
            </if>
            <if test="shareCount != null">
                share_count = #{shareCount},
            </if>
            <if test="isRecommended != null">
                is_recommended = #{isRecommended},
            </if>
            <if test="replayUrl != null and replayUrl != ''">
                replay_url = #{replayUrl},
            </if>
            <if test="duration != null">
                duration = #{duration},
            </if>
            <if test="createdAt != null">
                created_at = #{createdAt},
            </if>
            <if test="updatedAt != null">
                updated_at = #{updatedAt},
            </if>
            <if test="deletedAt != null">
                deleted_at = #{deletedAt},
            </if>
        </set>
        WHERE id = #{id}
    </update>

</mapper>