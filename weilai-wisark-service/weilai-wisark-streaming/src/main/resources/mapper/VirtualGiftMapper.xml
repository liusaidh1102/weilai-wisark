<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.weilai.streaming.mapper.VirtualGiftMapper">

    <resultMap type="com.weilai.model.streaming.dos.VirtualGift" id="VirtualGiftMap">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="price" column="price"/>
        <result property="imageUrl" column="image_url"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <!-- 添加虚拟礼物 -->
    <insert id="insert" parameterType="com.weilai.model.streaming.dos.VirtualGift">
        INSERT INTO `virtual_gift`(name, price, image_url, sort, status, created_at)
        VALUES (#{name}, #{price}, #{imageUrl}, #{sort}, #{status}, #{createdAt})
    </insert>

    <!-- 根据条件查询虚拟礼物 -->
    <select id="selectList" parameterType="com.baomidou.mybatisplus.core.conditions.query.QueryWrapper" 
            resultMap="VirtualGiftMap">
        SELECT * FROM `virtual_gift`
        <where>
            ${ew.sqlSegment}
        </where>
    </select>
    
    <!-- 根据ID查询虚拟礼物 -->
    <select id="selectById" parameterType="java.lang.Long" resultMap="VirtualGiftMap">
        SELECT * FROM `virtual_gift` WHERE id = #{id}
    </select>

    <!-- 更新虚拟礼物 -->
    <update id="updateById" parameterType="com.weilai.model.streaming.dos.VirtualGift">
        UPDATE `virtual_gift`
        <set>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="price != null">
                price = #{price},
            </if>
            <if test="imageUrl != null and imageUrl != ''">
                image_url = #{imageUrl},
            </if>
            <if test="sort != null">
                sort = #{sort},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="createdAt != null">
                created_at = #{createdAt},
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 删除虚拟礼物 -->
    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM `virtual_gift` WHERE id = #{id}
    </delete>

</mapper>