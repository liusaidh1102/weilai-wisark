<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.weilai.streaming.mapper.SystemNoticeMapper">

    <resultMap type="com.weilai.model.streaming.dos.SystemNotice" id="SystemNoticeMap">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="noticeType" column="notice_type"/>
        <result property="relatedId" column="related_id"/>
        <result property="isRead" column="is_read"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <!-- 添加系统通知 -->
    <insert id="insert" parameterType="com.weilai.model.streaming.dos.SystemNotice">
        INSERT INTO `system_notice`(user_id, title, content, notice_type, related_id, is_read, created_at)
        VALUES (#{userId}, #{title}, #{content}, #{noticeType}, #{relatedId}, #{isRead}, #{createdAt})
    </insert>

    <!-- 根据条件查询系统通知 -->
    <select id="selectList" parameterType="com.baomidou.mybatisplus.core.conditions.query.QueryWrapper" 
            resultMap="SystemNoticeMap">
        SELECT * FROM `system_notice`
        <where>
            ${ew.sqlSegment}
        </where>
    </select>
    
    <!-- 根据ID查询系统通知 -->
    <select id="selectById" parameterType="java.lang.Long" resultMap="SystemNoticeMap">
        SELECT * FROM `system_notice` WHERE id = #{id}
    </select>

    <!-- 更新系统通知 -->
    <update id="updateById" parameterType="com.weilai.model.streaming.dos.SystemNotice">
        UPDATE `system_notice`
        <set>
            <if test="userId != null">
                user_id = #{userId},
            </if>
            <if test="title != null and title != ''">
                title = #{title},
            </if>
            <if test="content != null and content != ''">
                content = #{content},
            </if>
            <if test="noticeType != null">
                notice_type = #{noticeType},
            </if>
            <if test="relatedId != null">
                related_id = #{relatedId},
            </if>
            <if test="isRead != null">
                is_read = #{isRead},
            </if>
            <if test="createdAt != null">
                created_at = #{createdAt},
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 删除系统通知 -->
    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM `system_notice` WHERE id = #{id}
    </delete>

</mapper>