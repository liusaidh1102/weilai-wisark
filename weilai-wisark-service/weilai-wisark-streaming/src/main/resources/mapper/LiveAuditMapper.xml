<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.weilai.streaming.mapper.LiveAuditMapper">

    <resultMap type="com.weilai.model.streaming.dos.LiveAudit" id="LiveAuditMap">
        <id property="id" column="id"/>
        <result property="liveId" column="live_id"/>
        <result property="messageId" column="message_id"/>
        <result property="auditType" column="audit_type"/>
        <result property="content" column="content"/>
        <result property="status" column="status"/>
        <result property="reviewerId" column="reviewer_id"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <!-- 添加直播审核 -->
    <insert id="insert" parameterType="com.weilai.model.streaming.dos.LiveAudit">
        INSERT INTO `live_audit`(live_id, message_id, audit_type, content, status, reviewer_id, created_at)
        VALUES (#{liveId}, #{messageId}, #{auditType}, #{content}, #{status}, #{reviewerId}, #{createdAt})
    </insert>

    <!-- 根据条件查询直播审核 -->
    <select id="selectList" parameterType="com.baomidou.mybatisplus.core.conditions.query.QueryWrapper" 
            resultMap="LiveAuditMap">
        SELECT * FROM `live_audit`
        <where>
            ${ew.sqlSegment}
        </where>
    </select>
    
    <!-- 根据ID查询直播审核 -->
    <select id="selectById" parameterType="java.lang.Long" resultMap="LiveAuditMap">
        SELECT * FROM `live_audit` WHERE id = #{id}
    </select>

    <!-- 更新直播审核 -->
    <update id="updateById" parameterType="com.weilai.model.streaming.dos.LiveAudit">
        UPDATE `live_audit`
        <set>
            <if test="liveId != null">
                live_id = #{liveId},
            </if>
            <if test="messageId != null">
                message_id = #{messageId},
            </if>
            <if test="auditType != null">
                audit_type = #{auditType},
            </if>
            <if test="content != null and content != ''">
                content = #{content},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="reviewerId != null">
                reviewer_id = #{reviewerId},
            </if>
            <if test="createdAt != null">
                created_at = #{createdAt},
            </if>
        </set>
        WHERE id = #{id}
    </update>

</mapper>