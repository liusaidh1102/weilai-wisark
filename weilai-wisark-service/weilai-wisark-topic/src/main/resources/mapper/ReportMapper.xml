<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.weilai.topic.mapper.ReportMapper">

    <resultMap type="com.weilai.model.topic.dos.Report" id="ReportMap">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="targetType" column="target_type"/>
        <result property="targetId" column="target_id"/>
        <result property="reasonType" column="reason_type"/>
        <result property="reason" column="reason"/>
        <result property="status" column="status"/>
        <result property="handlerId" column="handler_id"/>
        <result property="handleTime" column="handle_time"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 添加举报记录 -->
    <insert id="insert" parameterType="com.weilai.model.topic.dos.Report">
        INSERT INTO `report`(user_id, target_type, target_id, reason_type, reason, status, handler_id, handle_time, created_at, updated_at)
        VALUES (#{userId}, #{targetType}, #{targetId}, #{reasonType}, #{reason}, #{status}, #{handlerId}, #{handleTime}, #{createdAt}, #{updatedAt})
    </insert>

    <!-- 根据条件查询举报记录 -->
    <select id="selectList" parameterType="com.baomidou.mybatisplus.core.conditions.query.QueryWrapper" 
            resultMap="ReportMap">
        SELECT * FROM `report`
        <where>
            ${ew.sqlSegment}
        </where>
    </select>
    
    <!-- 根据ID查询举报记录 -->
    <select id="selectById" parameterType="java.lang.Long" resultMap="ReportMap">
        SELECT * FROM `report` WHERE id = #{id}
    </select>

    <!-- 更新举报记录 -->
    <update id="updateById" parameterType="com.weilai.model.topic.dos.Report">
        UPDATE `report`
        <set>
            <if test="userId != null">
                user_id = #{userId},
            </if>
            <if test="targetType != null">
                target_type = #{targetType},
            </if>
            <if test="targetId != null">
                target_id = #{targetId},
            </if>
            <if test="reasonType != null">
                reason_type = #{reasonType},
            </if>
            <if test="reason != null and reason != ''">
                reason = #{reason},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="handlerId != null">
                handler_id = #{handlerId},
            </if>
            <if test="handleTime != null">
                handle_time = #{handleTime},
            </if>
            <if test="createdAt != null">
                created_at = #{createdAt},
            </if>
            <if test="updatedAt != null">
                updated_at = #{updatedAt},
            </if>
        </set>
        WHERE id = #{id}
    </update>

</mapper>