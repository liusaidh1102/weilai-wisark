<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.weilai.topic.mapper.ArticleTagMapper">

    <resultMap type="com.weilai.model.topic.dos.ArticleTag" id="ArticleTagMap">
        <id property="id" column="id"/>
        <result property="articleId" column="article_id"/>
        <result property="tagId" column="tag_id"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <!-- 添加文章标签关联 -->
    <insert id="insert" parameterType="com.weilai.model.topic.dos.ArticleTag">
        INSERT INTO `article_tag`(article_id, tag_id, created_at)
        VALUES (#{articleId}, #{tagId}, #{createdAt})
    </insert>

    <!-- 根据条件查询文章标签关联 -->
    <select id="selectList" parameterType="com.baomidou.mybatisplus.core.conditions.query.QueryWrapper" 
            resultMap="ArticleTagMap">
        SELECT * FROM `article_tag`
        <where>
            ${ew.sqlSegment}
        </where>
    </select>
    
    <!-- 根据ID查询文章标签关联 -->
    <select id="selectById" parameterType="java.lang.Long" resultMap="ArticleTagMap">
        SELECT * FROM `article_tag` WHERE id = #{id}
    </select>

    <!-- 根据ID删除文章标签关联 -->
    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM `article_tag` WHERE id = #{id}
    </delete>

</mapper>