<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.weilai.topic.mapper.CollectionFolderMapper">

    <resultMap type="com.weilai.model.topic.dos.CollectionFolder" id="CollectionFolderMap">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="name" column="name"/>
        <result property="isDefault" column="is_default"/>
        <result property="articleCount" column="article_count"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deletedAt" column="deleted_at"/>
    </resultMap>

    <!-- 添加收藏文件夹 -->
    <insert id="insert" parameterType="com.weilai.model.topic.dos.CollectionFolder">
        INSERT INTO `collection_folder`(user_id, name, is_default, article_count, created_at, updated_at)
        VALUES (#{userId}, #{name}, #{isDefault}, #{articleCount}, #{createdAt}, #{updatedAt})
    </insert>

    <!-- 根据条件查询收藏文件夹 -->
    <select id="selectList" parameterType="com.baomidou.mybatisplus.core.conditions.query.QueryWrapper" 
            resultMap="CollectionFolderMap">
        SELECT * FROM `collection_folder`
        <where>
            ${ew.sqlSegment}
        </where>
    </select>
    
    <!-- 根据条件查询单个收藏文件夹 -->
    <select id="selectOne" parameterType="com.baomidou.mybatisplus.core.conditions.query.QueryWrapper" 
            resultMap="CollectionFolderMap">
        SELECT * FROM `collection_folder`
        <where>
            ${ew.sqlSegment}
        </where>
        LIMIT 1
    </select>

    <!-- 更新收藏文件夹 -->
    <update id="updateById" parameterType="com.weilai.model.topic.dos.CollectionFolder">
        UPDATE `collection_folder`
        <set>
            <if test="userId != null">
                user_id = #{userId},
            </if>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="isDefault != null">
                is_default = #{isDefault},
            </if>
            <if test="articleCount != null">
                article_count = #{articleCount},
            </if>
            <if test="createdAt != null">
                created_at = #{createdAt},
            </if>
            <if test="updatedAt != null">
                updated_at = #{updatedAt},
            </if>
            <if test="deletedAt != null">
                deleted_at = #{deletedAt},
            </if>
        </set>
        WHERE id = #{id}
    </update>

</mapper>